# Copy to .env and fill in values:
#   cp .env.example .env

### Server ###
PORT=3000
NODE_ENV=development
API_URL=
API_URL_DEV=http://localhost:3000
CLIENT_URL=
# Next dev default is often :3001 — must match browser origin for CORS + cookies
CLIENT_URL_DEV=http://localhost:3001

### Database (PostgreSQL) ###
DB_USER=postgres
DB_PASSWORD=asd
DB_ADDRESS=localhost
DB_PORT=5432
DB_NAME=sozluk

### JWT / tokens (use long random strings in production) ###
ACCESS_TOKEN_SECRET=change_me_access
REFRESH_TOKEN_SECRET=change_me_refresh
VERIFICATION_TOKEN_SECRET=change_me_verify

### Email (optional for local dev without mail) ###
SMPT_HOST=
SMPT_PORT=
SMPT_MAIL=
SMPT_PASSWORD=
